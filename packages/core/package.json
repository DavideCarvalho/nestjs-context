{
  "name": "@dudousxd/nestjs-context",
  "version": "1.0.0",
  "description": "Shared AsyncLocalStorage context for NestJS — carries user/tenant/traceId across the request and the ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/nestjs-context.git",
    "directory": "packages/core"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-diagnostics": ">=0.2.0",
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "reflect-metadata": ">=0.1.13"
  },
  "peerDependenciesMeta": {
    "@dudousxd/nestjs-diagnostics": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dudousxd/nestjs-diagnostics": "^0.2.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@types/node": "^20.0.0",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["nestjs", "context", "async-local-storage", "als", "trace", "tenant"]
}
